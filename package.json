{
  "name": "me3",
  "version": "0.1.0",
  "private": true,
  "description": "Installable ME3 Core assistant scaffold",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @me3-core/worker --filter @me3/web dev",
    "dev:worker": "pnpm --filter @me3-core/worker dev",
    "dev:web": "pnpm --filter @me3/web dev",
    "init:cloudflare": "node scripts/init-cloudflare.mjs",
    "generate:llms": "node scripts/generate-llms.mjs",
    "update:check": "node scripts/check-updates.mjs",
    "setup:dev-vars": "node scripts/create-dev-vars.mjs",
    "storage:r2:provision": "node scripts/provision-r2.mjs",
    "verify:local-boot": "node scripts/verify-local-boot.mjs",
    "build": "pnpm generate:llms && pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:migrations:apply": "wrangler d1 migrations apply DB --remote --config wrangler.toml",
    "deploy": "pnpm storage:r2:provision --yes && pnpm build && pnpm db:migrations:apply && wrangler deploy --config wrangler.toml",
    "deploy:d1-only": "pnpm build && pnpm db:migrations:apply && wrangler deploy --config wrangler.toml"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "wrangler": "^4.87.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
