{
  "name": "me3",
  "version": "0.1.1",
  "private": true,
  "description": "Personal OS and AI assistant",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @me3-core/worker --filter @me3/web dev",
    "dev:worker": "pnpm --filter @me3-core/worker dev",
    "dev:web": "pnpm --filter @me3/web dev",
    "init:cloudflare": "node scripts/init-cloudflare.mjs",
    "uninstall:cloudflare": "node scripts/uninstall-cloudflare.mjs",
    "destroy:cloudflare": "node scripts/uninstall-cloudflare.mjs",
    "generate:llms": "node scripts/generate-llms.mjs",
    "eval:models": "node scripts/evaluate-models.mjs",
    "update:check": "node scripts/check-updates.mjs",
    "update:core": "node scripts/update-core.mjs",
    "update:doctor": "node scripts/update-doctor.mjs",
    "deploy:prepare": "node scripts/prepare-cloudflare-deploy.mjs",
    "setup:dev-vars": "node scripts/create-dev-vars.mjs",
    "storage:r2:provision": "node scripts/provision-r2.mjs",
    "portable:export": "node scripts/portable.mjs export",
    "portable:restore": "node scripts/portable.mjs restore",
    "portable:verify": "node scripts/portable.mjs verify",
    "portable:compare": "node scripts/portable.mjs compare",
    "portable:proof": "node scripts/portable.mjs proof",
    "portable:test": "node --test scripts/portable-v1.test.mjs",
    "managed-install:test": "node --test scripts/configure-managed-install.test.mjs",
    "verify:local-boot": "node scripts/verify-local-boot.mjs",
    "build": "pnpm generate:llms && pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:migrations:apply": "wrangler d1 migrations apply DB --remote --config wrangler.toml",
    "deploy": "pnpm db:migrations:apply && wrangler deploy --config wrangler.toml",
    "deploy:cloudflare": "pnpm deploy:prepare && pnpm build && pnpm db:migrations:apply && wrangler deploy --config wrangler.toml",
    "deploy:cloudflare:d1-only": "pnpm deploy:cloudflare",
    "deploy:cloudflare:with-r2": "pnpm deploy:prepare -- --with-r2 && pnpm build && pnpm db:migrations:apply && wrangler deploy --config wrangler.toml"
  },
  "cloudflare": {
    "bindings": {
      "DB": {
        "description": "ME3 stores owner data, settings, jobs, and plugin state here. Use + Create new for a new install; Cloudflare provisions the D1 database automatically."
      },
      "ME3_USER_AGENT": {
        "description": "Durable Object state for ME3's owner agent runtime. Cloudflare provisions this automatically."
      },
      "AI": {
        "description": "Workers AI binding used by ME3's default assistant and voice features. You can add other model providers inside ME3 later."
      }
    }
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "wrangler": "^4.103.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "js-cookie": "3.0.8"
    }
  }
}
